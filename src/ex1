import sys
import pandas as pd

# csv読み込み用関数
def load_csv(file_path):
    return pd.read_csv(file_path)

# ステータス集計用関数
def calculate_status_summary(df):
    # CSVファイルのデータ数をtotalに格納
    total = len(df)
    # CSVファイルのStatusがPassであるデータ数をpass_countに格納
    pass_count = len(df[df["Status"] == "Pass"])
    # CSVファイルのStatusがFailであるデータ数をpass_countに格納
    fail_count = len(df[df["Status"] == "Fail"])
    # Pass率計算
    pass_rate = pass_count / total * 100 if total != 0 else 0
    return total,pass_count,fail_count,pass_rate

# 日付集計用関数
def calculate_daily_counts(df):
    return df["ExecutedDate"].value_counts().sort_index()

# 表示処理用関数
def print_status_summary(total,pass_count,fail_count,pass_rate):
    print(f"全体のテスト数: {total}")
    print(f"Pass: {pass_count}")
    print(f"Fail: {fail_count}")
    print(f"Pass率: {pass_rate:.0f}%")

# main関数
def main():
    # コマンドで渡されたファイル名を受け取る
    file_path = sys.argv[1]
    # CSV読み込み
    df = load_csv(file_path)

    total, pass_count, fail_count, pass_rate = calculate_status_summary(df)
    daily_counts = calculate_daily_counts(df)
    # 集計表示用関数呼び出し
    print_status_summary(total,pass_count,fail_count,pass_rate)
    print("\n日付ごとの実行件数")
    print(daily_counts)

# エントリーポイント
if __name__ == "__main__":
    main()